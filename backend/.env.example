NODE_ENV=development
API_PREFIX=/api/v1
LEGACY_UNVERSIONED_ROUTES_ENABLED=true
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
MAX_FILE_SIZE_BYTES=104857600
MAX_FILES_PER_UPLOAD=20
MAX_TOTAL_UPLOAD_BYTES=524288000
SUPPORTED_INPUT_CODECS=jpeg,jpg,png,webp,avif,tiff,heic,heif,raw,svg
SUPPORTED_OUTPUT_CODECS=jpeg,jpg,png,webp,avif
TEMP_DIR=.tmp
RETENTION_MINUTES=60
QUEUE_CONCURRENCY=2
PRESERVE_METADATA_DEFAULT=true
ENABLE_API_KEY_AUTH=false
API_KEY=
ENABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
